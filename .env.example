# ─────────────────────────────────────────────────────────────
#  LinguaFlow — Environment Variables Template
#  CodeAlpha AI Internship · Task 1: Language Translation Tool
#
#  HOW TO USE LOCALLY:
#    1. cp .env.example .env
#    2. Fill in your values in .env
#    3. ⚠️  Never commit .env to Git (it's in .gitignore)
#
#  FOR STREAMLIT CLOUD DEPLOYMENT:
#    Add these as Secrets in your app dashboard
#    (App → Settings → Secrets)
# ─────────────────────────────────────────────────────────────

# App display settings
APP_NAME=LinguaFlow
APP_TAGLINE=Translate anything, instantly — powered by Google Translate

# Translation settings
MAX_CHARS=5000
DEFAULT_TARGET_LANG=Telugu
